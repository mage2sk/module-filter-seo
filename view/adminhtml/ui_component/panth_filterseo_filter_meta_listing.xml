<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_filterseo_filter_meta_listing.panth_filterseo_filter_meta_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_filterseo_filter_meta_listing_columns</spinner>
        <deps>
            <dep>panth_filterseo_filter_meta_listing.panth_filterseo_filter_meta_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Filter Meta</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_filterseo_filter_meta_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_filterseo_filter_meta_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_filterseo_filter_meta_listing_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>id</indexField>
            </settings>
        </selectionsColumn>
        <column name="id">
            <settings>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="category_id">
            <settings>
                <label translate="true">Category ID</label>
            </settings>
        </column>
        <column name="attribute_code">
            <settings>
                <label translate="true">Attribute Code</label>
            </settings>
        </column>
        <column name="option_id">
            <settings>
                <label translate="true">Option ID</label>
            </settings>
        </column>
        <column name="store_id" class="Panth\FilterSeo\Ui\Component\Listing\Column\StoreView">
            <settings>
                <label translate="true">Store View</label>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="meta_title">
            <settings>
                <label translate="true">Meta Title</label>
            </settings>
        </column>
        <column name="meta_description">
            <settings>
                <label translate="true">Meta Description</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\FilterSeo\Ui\Component\Listing\Column\FilterMetaActions">
            <settings>
                <indexField>id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>

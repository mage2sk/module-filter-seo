<?xml version="1.0" encoding="UTF-8"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">panth_filterseo_filterrewrite_listing.panth_filterseo_filterrewrite_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>panth_filterseo_filterrewrite_listing_columns</spinner>
        <deps>
            <dep>panth_filterseo_filterrewrite_listing.panth_filterseo_filterrewrite_listing_data_source</dep>
        </deps>
        <buttons>
            <button name="add">
                <url path="*/*/new"/>
                <class>primary</class>
                <label translate="true">Add New Rewrite</label>
            </button>
        </buttons>
    </settings>
    <dataSource name="panth_filterseo_filterrewrite_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">rewrite_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <dataProvider class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider" name="panth_filterseo_filterrewrite_listing_data_source">
            <settings>
                <requestFieldName>rewrite_id</requestFieldName>
                <primaryFieldName>rewrite_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="panth_filterseo_filterrewrite_listing_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>rewrite_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="rewrite_id">
            <settings>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="attribute_code">
            <settings>
                <label translate="true">Attribute Code</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="option_label">
            <settings>
                <label translate="true">Option Label</label>
                <filter>text</filter>
            </settings>
        </column>
        <column name="rewrite_slug">
            <settings>
                <label translate="true">Rewrite Slug</label>
                <filter>text</filter>
                <editor>
                    <editorType>text</editorType>
                    <validation>
                        <rule name="required-entry" xsi:type="boolean">true</rule>
                    </validation>
                </editor>
            </settings>
        </column>
        <column name="store_id" class="Magento\Store\Ui\Component\Listing\Column\Store">
            <settings>
                <label translate="true">Store View</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <sortable>false</sortable>
            </settings>
        </column>
        <column name="is_active" component="Magento_Ui/js/grid/columns/select">
            <settings>
                <label translate="true">Active</label>
                <filter>select</filter>
                <dataType>select</dataType>
                <options class="Magento\Config\Model\Config\Source\Yesno"/>
                <editor>
                    <editorType>select</editorType>
                </editor>
            </settings>
        </column>
        <actionsColumn name="actions" class="Panth\FilterSeo\Ui\Component\Listing\Column\FilterRewriteActions">
            <settings>
                <indexField>rewrite_id</indexField>
            </settings>
        </actionsColumn>
    </columns>
</listing>
